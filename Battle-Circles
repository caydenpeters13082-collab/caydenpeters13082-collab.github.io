<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Circle Defense: Evolution</title>
    <style>
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; user-select: none; touch-action: none; }
        body { margin: 0; padding: 0; background: #05000a; color: #fff; font-family: sans-serif; overflow: hidden; height: 100vh; width: 100vw; }
        #hud { position: absolute; top: 0; width: 100%; height: 45px; display: flex; justify-content: space-around; align-items: center; background: rgba(0,0,0,0.9); z-index: 1000; border-bottom: 2px solid #ff0055; }
        .stat { color: #ff0055; font-weight: bold; font-family: monospace; font-size: 14px; }
        #arena { position: relative; width: 100%; height: 45vh; background: #020005; overflow: hidden; margin-top: 45px; border-bottom: 5px solid #ff0055; }
        #bottom-panel { position: relative; width: 100%; height: calc(55vh - 45px); background: #0a001a; z-index: 2000; display: flex; flex-direction: column; }
        #nav-tabs { display: flex; height: 40px; border-bottom: 1px solid #333; flex-shrink: 0; }
        .tab-btn { flex: 1; background: #110022; border: none; color: #888; font-weight: bold; font-size: 12px; cursor: pointer; }
        .tab-btn.active { background: #3b0080; color: #fff; border-bottom: 2px solid #00ffcc; }
        .content-pane { display: none; flex-grow: 1; overflow-y: auto; padding: 6px; }
        .content-pane.active { display: block; }
        #shop { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; padding-bottom: 20px; }
        .buy-btn, .skill-btn { background: #1a0033; border: 1px solid #ff0055; border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 10px 2px; position: relative; cursor: pointer; }
        .buy-btn.locked { opacity: 0.2; filter: grayscale(1); pointer-events: none; }
        .buy-btn b, .skill-btn b { font-size: 8px; color: #fff; text-align: center; }
        .buy-btn i, .skill-btn i { font-size: 8px; color: #00ffcc; font-style: normal; margin-top: 2px; }
        .unlock-tag { position: absolute; top: -5px; background: #ff0055; font-size: 7px; padding: 1px 3px; border-radius: 3px; z-index: 10; }
        #upgrade-menu { display: none; flex-direction: column; align-items: center; padding: 10px; background: #110022; height: 100%; }
        .action-btn { background: #3b0080; border: 2px solid #00ffcc; color: #fff; padding: 12px; font-weight: bold; border-radius: 8px; margin: 4px; width: 90%; cursor: pointer; }
        .unit, .enemy { position: absolute; border-radius: 50%; transform: translate(-50%, -50%); pointer-events: none; transition: transform 0.1s; }
        .selected { box-shadow: 0 0 20px 8px #fff !important; z-index: 20; border: 3px solid #fff; }
        .enemy { border-radius: 4px; background: #00ffa3; box-shadow: 0 0 10px #00ffa3; }
        .boss { background: #ff0055; box-shadow: 0 0 20px #ff0055; }
        .mega { background: #ffcc00; box-shadow: 0 0 40px #ffcc00; border: 4px solid #fff; }
        .mega.rage { background: #ff0000; box-shadow: 0 0 60px #ff0000; animation: shake 0.2s infinite; }
        @keyframes shake { 0% { transform: translate(-52%, -50%); } 50% { transform: translate(-48%, -50%); } 100% { transform: translate(-50%, -50%); } }
        
        /* UNIQUE VISUALS */
        .v-aura { box-shadow: 0 0 15px 5px currentColor; }
        .v-spin { border: 2px dashed #fff; animation: rotate 3s linear infinite; }
        .v-pulse { animation: pulse 1.5s infinite; }
        @keyframes rotate { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
        .crown::after { content: '👑'; position: absolute; top: -20px; left: 50%; transform: translateX(-50%); font-size: 14px; }

        .hp-bar { position: absolute; top: -10px; left: 0; width: 100%; height: 4px; background: #200040; border-radius: 2px; }
        .hp-fill { height: 100%; background: #00ffcc; width: 100%; border-radius: 2px; }
        .bullet { position: absolute; width: 6px; height: 6px; border-radius: 50%; background: #ff0055; }
        .dmg-text { position: absolute; color: #fff; font-size: 12px; font-weight: bold; pointer-events: none; animation: floatUp 0.8s ease-out forwards; z-index: 3000; }
        @keyframes floatUp { 0% { opacity: 1; transform: translate(-50%, -50%); } 100% { opacity: 0; transform: translate(-50%, -100px); } }
    </style>
</head>
<body>

<div id="hud">
    <div class="stat">$ <span id="gold-ui">800</span></div>
    <div class="stat">❤️ <span id="lives-ui">60</span></div>
    <div class="stat">WAVE <span id="wave-ui">1</span></div>
</div>
<div id="arena"><div id="spawn-pad"></div></div>
<div id="bottom-panel">
    <div id="nav-tabs">
        <button class="tab-btn active" id="tab-shop" onclick="showTab('shop-pane')">SHOP</button>
        <button class="tab-btn" id="tab-skills" onclick="showTab('skills-pane')">SKILLS</button>
    </div>
    
    <div id="shop-pane" class="content-pane active">
        <div id="shop">
            <div class="buy-btn" onclick="buy('slasher')"><b>⚔️ SLASHER</b><i>$200</i></div>
            <div class="buy-btn" onclick="buy('archer')"><b>🏹 ARCHER</b><i>$250</i></div>
            <div class="buy-btn" onclick="buy('assassin')"><b>⚡ ASSASSIN</b><i>$300</i></div>
            <div class="buy-btn" onclick="buy('mage')"><b>❄️ MAGE</b><i>$350</i></div>
            <div class="buy-btn" onclick="buy('guardian')"><b>🛡️ GUARDIAN</b><i>$400</i></div>
            <div class="buy-btn" onclick="buy('paladin')"><b>✨ PALADIN</b><i>$550</i></div>
            <div class="buy-btn" onclick="buy('striker')"><b>🥊 STRIKER</b><i>$600</i></div>
            <div class="buy-btn" onclick="buy('bard')"><b>🎵 BARD</b><i>$800</i></div>
            <div class="buy-btn" onclick="buy('sniper')"><b>🎯 SNIPER</b><i>$900</i></div>
            <div class="buy-btn" onclick="buy('tesla')"><b>🌀 TESLA</b><i>$1200</i></div>
            <div class="buy-btn" onclick="buy('gravity')"><b>🌑 GRAVITY</b><i>$1500</i></div>
            <div class="buy-btn" onclick="buy('reaper')"><b>💀 REAPER</b><i>$2000</i></div>
            <div class="buy-btn locked" id="btn-vindicator" onclick="buy('vindicator')"><span class="unlock-tag">W15</span><b>🔥 VIND</b><i>$2500</i></div>
            <div class="buy-btn locked" id="btn-sentinel" onclick="buy('sentinel')"><span class="unlock-tag">W30</span><b>🛰️ SENT</b><i>$4000</i></div>
            <div class="buy-btn locked" id="btn-singularity" onclick="buy('singularity')"><span class="unlock-tag">W50</span><b>🌌 SING</b><i>$7500</i></div>
            <div class="buy-btn" style="border-color:#00ffcc" onclick="repairBase()"><b>🔧 REPAIR</b><i>$1000</i></div>
        </div>
    </div>

    <div id="skills-pane" class="content-pane">
        <div id="shop" style="grid-template-columns: repeat(3, 1fr);">
            <div class="skill-btn" onclick="upgradeSkill('hp')"><b>🛡️ FORT</b><i id="skill-hp-cost">$500</i><span id="skill-hp-lv" style="font-size:10px">Lv 0</span></div>
            <div class="skill-btn" onclick="upgradeSkill('spd')"><b>⚡ ADREN</b><i id="skill-spd-cost">$500</i><span id="skill-spd-lv" style="font-size:10px">Lv 0</span></div>
            <div class="skill-btn" onclick="upgradeSkill('gold')"><b>💰 GOLD</b><i id="skill-gold-cost">$500</i><span id="skill-gold-lv" style="font-size:10px">Lv 0</span></div>
        </div>
    </div>

    <div id="upgrade-menu">
        <h3 id="upg-title" style="margin:0; color:#00ffcc;">Unit</h3>
        <button class="action-btn" id="btn-upg" onclick="upgradeSelected()">Upgrade</button>
        <button class="action-btn" id="btn-fuse" style="display:none; background:#ffaa00" onclick="fuseSelected()">FUSE (God Tier)</button>
        <button class="action-btn" onclick="selectedUnit.recalling = !selectedUnit.recalling; updateUpgMenu();">Recall/Deploy</button>
        <button class="action-btn" style="border-color:#ff0055" onclick="sellSelected()">Sell</button>
    </div>
</div>

<script>
let gold = 800, lives = 60, wave = 1, units = [], enemies = [], bullets = [], selectedUnit = null, gameActive = true, hyperdriveEnd = 0;
const arena = document.getElementById('arena'), W = window.innerWidth;
let skills = { hp: 0, spd: 0, gold: 0 };
let actx = null;

const U_DATA = {
    slasher: { c: 200, col: '#ff0070', hp: 450, r: 85, spd: 1.5, vis: 'v-aura' },
    archer: { c: 250, col: '#00d0ff', hp: 200, r: 150, spd: 1.2, vis: 'v-spin' },
    assassin: { c: 300, col: '#7000ff', hp: 250, r: 95, spd: 2.1, vis: 'v-pulse' },
    mage: { c: 350, col: '#00ffcc', hp: 200, r: 180, spd: 1.2, vis: 'v-aura' },
    guardian: { c: 400, col: '#555', hp: 1500, r: 50, spd: 0.2, vis: 'v-aura' },
    paladin: { c: 550, col: '#ffcc00', hp: 600, r: 120, spd: 1.1, vis: 'v-pulse' },
    striker: { c: 600, col: '#ff8800', hp: 500, r: 105, spd: 1.8, vis: 'v-spin' },
    bard: { c: 800, col: '#ff55aa', hp: 400, r: 120, spd: 1.6, vis: 'v-aura' },
    sniper: { c: 900, col: '#eeeeee', hp: 200, r: 180, spd: 0.8, vis: 'v-spin' },
    tesla: { c: 1200, col: '#00ffff', hp: 400, r: 140, spd: 0.8, vis: 'v-aura' },
    gravity: { c: 1500, col: '#aa00ff', hp: 500, r: 180, spd: 0.7, vis: 'v-aura' },
    reaper: { c: 2000, col: '#444', hp: 600, r: 140, spd: 1.5, vis: 'v-pulse' },
    vindicator: { c: 2500, col: '#ff4400', hp: 800, r: 150, spd: 2.5, vis: 'v-aura' },
    sentinel: { c: 4000, col: '#00ff00', hp: 1000, r: 250, spd: 0.5, vis: 'v-spin' },
    singularity: { c: 7500, col: '#ffffff', hp: 2000, r: 500, spd: 0.3, vis: 'v-aura' }
};

function playSfx(f, d, t='square') {
    if(!actx) actx = new (window.AudioContext || window.webkitAudioContext)();
    let o = actx.createOscillator(), g = actx.createGain();
    o.type = t; o.frequency.setValueAtTime(f, actx.currentTime);
    g.gain.setValueAtTime(0.05, actx.currentTime); g.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + d);
    o.connect(g); g.connect(actx.destination); o.start(); o.stop(actx.currentTime + d);
}

function showTab(id) {
    document.querySelectorAll('.content-pane').forEach(p => { p.classList.remove('active'); p.style.display = ''; });
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    if(id==='shop-pane') document.getElementById('tab-shop').classList.add('active');
    if(id==='skills-pane') document.getElementById('tab-skills').classList.add('active');
}

function updateUpgMenu() {
    if(!selectedUnit) return;
    let u = selectedUnit;
    let upCost = Math.floor(U_DATA[u.type].c * Math.pow(1.3, u.lv));
    document.getElementById('upg-title').innerText = `${u.type.toUpperCase()} (Lv ${u.lv})${u.fused?' GOD':''}`;
    document.getElementById('btn-upg').innerText = u.lv >= 3 ? "MAXED" : `Upgrade ($${upCost})`;
    
    // Fusion Check
    let partner = units.find(un => un !== u && un.type === u.type && un.lv === 3 && !un.fused);
    document.getElementById('btn-fuse').style.display = (u.lv === 3 && !u.fused && partner) ? 'block' : 'none';
}

function upgradeSelected() {
    if(!selectedUnit || selectedUnit.lv >= 3) return;
    let cost = Math.floor(U_DATA[selectedUnit.type].c * Math.pow(1.3, selectedUnit.lv));
    if(gold >= cost) { 
        gold -= cost; selectedUnit.lv++; 
        selectedUnit.maxHp *= 1.6; selectedUnit.hp = selectedUnit.maxHp; 
        updateUI(); updateUpgMenu(); playSfx(300, 0.2);
    }
}

function fuseSelected() {
    let u = selectedUnit;
    let partner = units.find(un => un !== u && un.type === u.type && un.lv === 3 && !un.fused);
    if(partner) {
        partner.el.remove(); units = units.filter(un => un !== partner);
        u.fused = true; u.maxHp *= 2.5; u.hp = u.maxHp; u.el.classList.add('crown');
        playSfx(800, 0.5, 'sawtooth'); updateUpgMenu(); updateUI();
    }
}

function buy(type) {
    if(gold < U_DATA[type].c) return;
    gold -= U_DATA[type].c; updateUI();
    let el = document.createElement('div'); el.className = `unit ${U_DATA[type].vis}`;
    el.innerHTML = '<div class="hp-bar"><div class="hp-fill"></div></div>';
    el.style.background = U_DATA[type].col; el.style.color = U_DATA[type].col; el.style.width = '30px'; el.style.height = '30px';
    arena.appendChild(el);
    let baseHp = U_DATA[type].hp * (1 + skills.hp * 0.1);
    units.push({ el, type, lv: 1, x: W/2, y: 350, hp: baseHp, maxHp: baseHp, r: U_DATA[type].r, lastAtk: 0, vx: 0, vy: 0, recalling: false, fused: false });
    playSfx(400, 0.1);
}

arena.addEventListener('pointerdown', (e) => {
    let rect = arena.getBoundingClientRect(), ex = e.clientX - rect.left, ey = e.clientY - rect.top;
    let closest = units.find(u => Math.hypot(u.x - ex, u.y - ey) < 40);
    units.forEach(u => u.el.classList.remove('selected'));
    if(closest) {
        selectedUnit = closest; closest.el.classList.add('selected');
        document.getElementById('shop-pane').style.display = 'none';
        document.getElementById('skills-pane').style.display = 'none';
        document.getElementById('nav-tabs').style.display = 'none';
        document.getElementById('upgrade-menu').style.display = 'flex';
        updateUpgMenu();
    } else {
        selectedUnit = null; 
        document.getElementById('nav-tabs').style.display = 'flex';
        document.getElementById('upgrade-menu').style.display = 'none';
        showTab('shop-pane');
    }
});

function loop() {
    if(!gameActive) return;
    let now = Date.now();
    let isHyper = now < hyperdriveEnd;
    if(isHyper) arena.style.background = '#1a001a'; else arena.style.background = '#020005';

    enemies.forEach((e, ei) => {
        if(e.y > 425) { lives--; e.el.remove(); enemies.splice(ei, 1); updateUI(); if(lives <= 0) gameActive = false; return; }
        
        let moveSpd = (e.isMega && e.hp < e.maxHp/2) ? 0.15 : (e.isMega ? 0.05 : 0.15);
        if(now > e.freeze) e.y += moveSpd;
        if(e.isMega && e.hp < e.maxHp/2 && !e.el.classList.contains('rage')) { e.el.classList.add('rage'); playSfx(100, 1, 'sawtooth'); }

        let fireRate = e.isMega ? (e.hp < e.maxHp/2 ? 400 : 1000) : 3500;
        if(now - e.lastShot > fireRate) {
            let count = (e.isMega && e.hp < e.maxHp/2) ? 16 : (e.isMega ? 8 : 1);
            for(let i=0; i<count; i++) {
                let a = (Math.PI * 2 / count) * i + (e.isMega ? now/500 : 0);
                let b = document.createElement('div'); b.className = 'bullet'; arena.appendChild(b);
                bullets.push({ el: b, x: e.x, y: e.y, vx: Math.cos(a)*4, vy: Math.sin(a)*4, dmg: 15+(wave*2), isP: false });
            }
            e.lastShot = now;
        }
    });

    bullets.forEach(b => {
        b.x += b.vx; b.y += b.vy; b.el.style.left = b.x+'px'; b.el.style.top = b.y+'px';
        if(b.isP) enemies.forEach(e => { if(Math.hypot(b.x-e.x, b.y-e.y) < e.size/2) { e.hp -= b.dmg; b.rem = true; }});
        else units.forEach(u => { if(Math.hypot(b.x-u.x, b.y-u.y) < 15) { u.hp -= b.dmg; b.rem = true; }});
        if(b.x<0 || b.x>W || b.y<0 || b.y>500) b.rem = true;
    });
    bullets = bullets.filter(b => { if(b.rem) b.el.remove(); return !b.rem; });

    units.forEach((u, ui) => {
        let target = enemies.reduce((prev, curr) => (Math.hypot(curr.x-u.x, curr.y-u.y) < Math.hypot(prev.x-u.x, prev.y-u.y)) ? curr : prev, enemies[0]);
        if(u.recalling) {
            let dx = W/2 - u.x, dy = 350 - u.y, d = Math.hypot(dx,dy);
            u.vx = d > 5 ? dx/d * 4 : 0; u.vy = d > 5 ? dy/d * 4 : 0;
            u.hp = Math.min(u.maxHp, u.hp + 1);
        } else if(target) {
            let dx = target.x - u.x, dy = target.y - u.y, d = Math.hypot(dx,dy);
            let keepDist = u.r * 0.8; 
            if(d < keepDist) {
                u.vx *= 0.8; u.vy *= 0.8;
                if(now - u.lastAtk > (isHyper ? 500 : 1000)) {
                    let mult = (u.fused ? 3 : 1) * (isHyper ? 2 : 1);
                    if(u.type==='archer'||u.type==='sniper'||u.type==='sentinel') {
                        let b = document.createElement('div'); b.className = 'bullet'; b.style.background = '#fff'; arena.appendChild(b);
                        bullets.push({ el: b, x: u.x, y: u.y, vx: (dx/d)*15, vy: (dy/d)*15, dmg: 50*u.lv*mult, isP: true });
                    } else if(u.type==='slasher'||u.type==='striker'||u.type==='assassin') {
                        target.hp -= 80*u.lv*mult; u.vx = -dx/d*10; u.vy = -dy/d*10;
                    } else { // AOE/Other
                        enemies.forEach(en => { if(Math.hypot(en.x-u.x, en.y-u.y) < u.r) en.hp -= 40*u.lv*mult; });
                    }
                    u.lastAtk = now; playSfx(600, 0.05);
                }
            } else { 
                let spd = (U_DATA[u.type].spd || 1) * (1 + skills.spd * 0.1);
                u.vx += dx/d * 0.2 * spd; u.vy += dy/d * 0.2 * spd;
            }
        }
        u.x += u.vx; u.y += u.vy;
        u.el.style.left = u.x+'px'; u.el.style.top = u.y+'px';
        u.el.querySelector('.hp-fill').style.width = (u.hp/u.maxHp*100)+'%';
        if(u.hp <= 0) { u.el.remove(); units.splice(ui, 1); playSfx(100, 0.3); }
    });

    enemies.forEach((en, ei) => {
        en.el.style.left = en.x+'px'; en.el.style.top = en.y+'px';
        en.el.querySelector('.hp-fill').style.width = (en.hp/en.maxHp*100)+'%';
        if(en.hp <= 0) { 
            if(en.isB || en.isMega) hyperdriveEnd = now + 10000;
            en.el.remove(); enemies.splice(ei, 1); 
            gold += (en.isMega?5000:en.isB?1500:150) * (1+skills.gold*0.2); updateUI();
        }
    });

    if(enemies.length === 0) { wave++; spawnWave(); updateUI(); }
    requestAnimationFrame(loop);
}

function spawnWave() {
    let isMega = (wave % 50 === 0), isB = (wave % 10 === 0 && !isMega);
    let hp = 100 * Math.pow(1.18, wave) * (isMega?250:isB?25:1);
    let count = (isMega||isB) ? 1 : Math.min(wave, 10);
    for(let i=0; i<count; i++) {
        let el = document.createElement('div'); el.className = 'enemy' + (isB?' boss':'') + (isMega?' mega':'');
        el.innerHTML = '<div class="hp-bar"><div class="hp-fill"></div></div>';
        let size = isMega ? 120 : (isB ? 80 : 35); el.style.width = size+'px'; el.style.height = size+'px';
        arena.appendChild(el);
        enemies.push({ el, size, x: Math.random()*W, y: -50, hp, maxHp: hp, isB, isMega, lastShot: 0 });
    }
}

function upgradeSkill(t) {
    let c = 500 * Math.pow(2, skills[t]);
    if(gold >= c) { gold -= c; skills[t]++; updateUI(); updateSkillUI(); playSfx(500, 0.2); }
}

function updateUI() { document.getElementById('gold-ui').innerText = Math.floor(gold); document.getElementById('lives-ui').innerText = lives; document.getElementById('wave-ui').innerText = wave; }
function updateSkillUI() { ['hp','spd','gold'].forEach(t => { document.getElementById(`skill-${t}-cost`).innerText = `$${500 * Math.pow(2, skills[t])}`; document.getElementById(`skill-${t}-lv`).innerText = `Lv ${skills[t]}`; }); }
function sellSelected() { if(!selectedUnit) return; gold += U_DATA[selectedUnit.type].c*0.5; selectedUnit.el.remove(); units = units.filter(un => un !== selectedUnit); selectedUnit = null; showTab('shop-pane'); updateUI(); }
function repairBase() { if(gold >= 1000 && lives < 60) { gold -= 1000; lives = Math.min(60, lives+10); updateUI(); playSfx(700, 0.3); } }

spawnWave(); updateSkillUI(); loop();
</script>
</body>
</html>
